# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
Gourmet Heaven/[Ll]ibrary/*
Gourmet Heaven/[Tt]emp/
Gourmet Heaven/[Oo]bj/
Gourmet Heaven/[Bb]uild/
Gourmet Heaven/[Bb]uilds/
Gourmet Heaven/[Ll]ogs/
Gourmet Heaven/[Uu]ser[Ss]ettings/

# Force include scene hierarchy
!/Gourmet Heaven/[Ll]ibrary/LastSceneManagerSetup.txt

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
Gourmet Heaven/[Mm]emoryCaptures/

# Recordings can get excessive in size
Gourmet Heaven/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
Gourmet Heaven/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
Gourmet Heaven/.vs/

# Gradle cache directory
Gourmet Heaven/.gradle/
Gourmet Heaven/.utmp

# Autogenerated VS/MD/Consulo solution and project files
Gourmet Heaven/ExportedObj/
Gourmet Heaven/.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
Gourmet Heaven/sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
Gourmet Heaven/crashlytics-build.properties

# Packed Addressables
Gourmet Heaven/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
Gourmet Heaven/[Aa]ssets/[Ss]treamingAssets/aa.meta
Gourmet Heaven/[Aa]ssets/[Ss]treamingAssets/aa/*
Gourmet Heaven/Assets/Resources/PerformanceTestRunSettings.json.meta
Gourmet Heaven/Assets/Resources/PerformanceTestRunSettings.json
Gourmet Heaven/Assets/Resources/PerformanceTestRunInfo.json.meta
Gourmet Heaven/Assets/Resources/PerformanceTestRunInfo.json
~$Gourmet Heaven.pptx
Gourmet Heaven/Library/LastSceneManagerSetup.txt
GourmetHeavenAppKeyStore.keystore

RELEASE/*